<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.igirepaypaymentgateway.ui.controller.AccountsController"
            style="-fx-background-color:white;"
            maxWidth="Infinity" maxHeight="Infinity">
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
            <Button text="←" styleClass="header-icon-btn" onAction="#onDashboard"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="My Accounts" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="header-icon-btn" onAction="#onDashboard"/>
        </HBox>
    </top>
    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true" hbarPolicy="NEVER">
            <VBox spacing="16" style="-fx-padding: 20 20 20 20; -fx-background-color:white;">

                <Label text="YOUR ACCOUNTS" styleClass="section-header"/>
                <TableView fx:id="accountsTable" prefHeight="220" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"           prefWidth="60"/>
                        <TableColumn fx:id="colType"     text="Type"         prefWidth="110"/>
                        <TableColumn fx:id="colBalance"  text="Balance (RWF)" prefWidth="150"/>
                        <TableColumn fx:id="colCurrency" text="Currency"     prefWidth="80"/>
                        <TableColumn fx:id="colCreated"  text="Created"      prefWidth="150"/>
                    </columns>
                    <placeholder>
                        <Label text="No accounts yet." styleClass="page-subtitle"/>
                    </placeholder>
                </TableView>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="🗑  Delete Selected" styleClass="btn-accent"
                            style="-fx-pref-height:42px; -fx-background-radius:10;"
                            onAction="#onDeleteAccount"/>
                    <Label fx:id="deleteStatusLabel" styleClass="msg-error"/>
                </HBox>

                <Separator/>

                <Label text="CREATE NEW ACCOUNT" styleClass="section-header"/>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="ACCOUNT TYPE" styleClass="form-section-label"/>
                        <ComboBox fx:id="accountTypeCombo" maxWidth="Infinity"
                                  styleClass="combo-input"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="INITIAL DEPOSIT (RWF)" styleClass="form-section-label"/>
                        <TextField fx:id="initialBalanceField" promptText="0"
                                   styleClass="input-field" maxWidth="Infinity"/>
                    </VBox>
                </HBox>
                <Button text="CREATE ACCOUNT" styleClass="btn-teal"
                        maxWidth="Infinity" onAction="#onCreateAccount"/>
                <Label fx:id="createStatusLabel" styleClass="msg-error"
                       wrapText="true" maxWidth="Infinity"/>

                <Region prefHeight="20"/>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <HBox styleClass="bottom-nav-bar" alignment="CENTER">
            <Button styleClass="nav-btn" onAction="#onDashboard" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3"><Label text="🏠" styleClass="nav-btn-icon"/><Label text="Home" styleClass="nav-btn-label"/></VBox></graphic>
            </Button>
            <Button styleClass="nav-btn" onAction="#onSendMoney" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3"><Label text="✈" styleClass="nav-btn-icon"/><Label text="Send" styleClass="nav-btn-label"/></VBox></graphic>
            </Button>
            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <Circle radius="31" fill="#F5A623" style="-fx-effect: dropshadow(gaussian,rgba(245,166,35,0.5),12,0,0,0);"/>
                <VBox alignment="CENTER" spacing="1" onMouseClicked="#onSendMoney" style="-fx-cursor:hand;">
                    <Label text="IRO" style="-fx-text-fill:#0D4F6C; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <Label text="Pay" style="-fx-text-fill:#0D4F6C; -fx-font-size:10px;"/>
                </VBox>
            </StackPane>
            <Button styleClass="nav-btn" onAction="#onTransactions" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3"><Label text="📋" styleClass="nav-btn-icon"/><Label text="History" styleClass="nav-btn-label"/></VBox></graphic>
            </Button>
            <Button styleClass="nav-btn" onAction="#onAccounts" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3"><Label text="🏦" styleClass="nav-btn-icon-active"/><Label text="Accounts" styleClass="nav-btn-label-active"/></VBox></graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
