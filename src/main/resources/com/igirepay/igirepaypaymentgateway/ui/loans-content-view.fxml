<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.igirepay.igirepaypaymentgateway.ui.controller.LoansContentController"
      spacing="20" style="-fx-padding: 24 20 20 20; -fx-background-color:white;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="💰 My Loans" 
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ Apply for Loan" 
                styleClass="btn-primary" onAction="#onApplyForLoan"/>
        <Button text="🔄 Refresh" 
                styleClass="btn-secondary" onAction="#onRefresh"/>
    </HBox>

    <!-- Filter Tabs -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="filterAllBtn" text="All Loans" 
                styleClass="filter-btn-active" onAction="#onFilterAll"/>
        <Button fx:id="filterActiveBtn" text="Active" 
                styleClass="filter-btn" onAction="#onFilterActive"/>
        <Button fx:id="filterPendingBtn" text="Pending" 
                styleClass="filter-btn" onAction="#onFilterPending"/>
        <Button fx:id="filterPaidBtn" text="Paid" 
                styleClass="filter-btn" onAction="#onFilterPaid"/>
    </HBox>

    <!-- Loans List -->
    <ScrollPane styleClass="scroll-pane" fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="loansBox" spacing="12" style="-fx-padding: 10;"/>
    </ScrollPane>

</VBox>
