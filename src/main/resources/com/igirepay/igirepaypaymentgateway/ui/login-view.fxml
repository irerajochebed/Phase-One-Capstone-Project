<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.igirepay.igirepaypaymentgateway.ui.controller.LoginController"
           styleClass="login-bg">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="scroll-pane">
        <VBox alignment="CENTER" fillWidth="true" style="-fx-padding: 60 0 60 0;">

            <!-- Card centred, max 520px -->
            <VBox maxWidth="520" minWidth="300" alignment="CENTER" spacing="0"
                  style="-fx-padding: 0 48 0 48;">

                <!-- ── IRO Logo ── -->
                <VBox alignment="CENTER" spacing="10">
                    <!-- Logo Image -->
                    <ImageView fx:id="loginLogoView" fitWidth="120" fitHeight="120" preserveRatio="true"/>

                    <!-- App name -->
                    <HBox alignment="CENTER" spacing="0">
                        <Label text="Igire" style="-fx-text-fill:#F5A623; -fx-font-size:28px; -fx-font-weight:bold;"/>
                        <Label text="Pay" style="-fx-text-fill:#0D4F6C; -fx-font-size:28px; -fx-font-weight:bold;"/>
                    </HBox>
                    <Label text="Igire Rwanda Organization" styleClass="app-subtitle"/>
                </VBox>

                <Region prefHeight="48"/>

                <!-- ── Account selector ── -->
                <Label text="SELECT ACCOUNT" styleClass="form-section-label"/>
                <Region prefHeight="8"/>
                <ComboBox fx:id="accountCombo" maxWidth="Infinity"
                          styleClass="combo-input"
                          promptText="Choose your account..."/>

                <Region prefHeight="28"/>

                <!-- ── PIN field ── -->
                <HBox alignment="CENTER_LEFT">
                    <Label text="PIN" styleClass="pin-label" HBox.hgrow="ALWAYS"/>
                    <Button text="👁" styleClass="header-icon-btn"
                            style="-fx-text-fill:#6B7280;"
                            onAction="#onTogglePin"/>
                </HBox>
                <PasswordField fx:id="pinField" promptText="Enter your PIN"
                               styleClass="pin-input" maxWidth="Infinity"/>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 4 0 0 0;">
                    <Button text="Forgot PIN?" styleClass="btn-link" onAction="#onForgotPin"/>
                </HBox>

                <Region prefHeight="8"/>

                <!-- Error label -->
                <Label fx:id="errorLabel" styleClass="msg-error"
                       wrapText="true" maxWidth="Infinity" minHeight="20"/>

                <Region prefHeight="20"/>

                <!-- ── Sign In button ── -->
                <Button text="SIGN IN" styleClass="btn-main"
                        maxWidth="Infinity" onAction="#onLogin"/>

                <Region prefHeight="20"/>

                <Button text="Switch account" styleClass="btn-ghost"
                        maxWidth="Infinity" alignment="CENTER"
                        onAction="#onSwitchAccount"/>

                <Region prefHeight="16"/>

                <Label text="By using this app you agree to our Terms &amp; Conditions"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:12px;"
                       wrapText="true" maxWidth="Infinity" alignment="CENTER"/>

                <Region prefHeight="28"/>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="New user?" style="-fx-text-fill:#6B7280; -fx-font-size:13px;"/>
                    <Button text="Create Account" styleClass="btn-link" onAction="#onGoRegister"/>
                </HBox>

                <Region prefHeight="40"/>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
