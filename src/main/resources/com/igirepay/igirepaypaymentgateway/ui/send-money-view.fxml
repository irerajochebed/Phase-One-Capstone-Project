<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.igirepaypaymentgateway.ui.controller.SendMoneyController"
            style="-fx-background-color:white;"
            maxWidth="Infinity" maxHeight="Infinity">

    <!-- Header -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
            <Button text="←" styleClass="header-icon-btn" onAction="#onBack"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Send money to" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="header-icon-btn" onAction="#onBack"/>
        </HBox>
    </top>

    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true" hbarPolicy="NEVER">
            <VBox spacing="20" style="-fx-padding: 24 20 20 20; -fx-background-color:white;">

                <!-- Send type selector — white card with divider like MoMo -->
                <HBox styleClass="send-type-box" alignment="CENTER">
                    <VBox fx:id="iroUserCard" styleClass="send-type-btn"
                          alignment="CENTER" spacing="8"
                          onMouseClicked="#onSelectIROUser" HBox.hgrow="ALWAYS">
                        <Label text="💸" styleClass="send-type-icon"/>
                        <Label text="IROPay user" styleClass="send-type-label"/>
                    </VBox>
                    <!-- Orange vertical divider -->
                    <Region styleClass="send-type-divider"/>
                    <VBox fx:id="bankCard" styleClass="send-type-btn"
                          alignment="CENTER" spacing="8"
                          onMouseClicked="#onSelectBank" HBox.hgrow="ALWAYS">
                        <Label text="🏦" styleClass="send-type-icon"/>
                        <Label text="Bank Account" styleClass="send-type-label"/>
                    </VBox>
                </HBox>

                <!-- Transfer form -->
                <VBox spacing="14">
                    <Label text="FROM ACCOUNT" styleClass="form-section-label"/>
                    <ComboBox fx:id="fromAccountCombo" maxWidth="Infinity"
                              styleClass="combo-input"/>

                    <Label fx:id="toLabel" text="RECIPIENT PHONE NUMBER" styleClass="form-section-label"/>
                    <TextField fx:id="toAccountField"
                               promptText="e.g. 0781234567"
                               styleClass="input-field" maxWidth="Infinity"/>

                    <!-- Recipient lookup result -->
                    <Label fx:id="recipientLabel" text=""
                           style="-fx-text-fill:#0D4F6C; -fx-font-size:13px; -fx-font-weight:bold;"/>

                    <Label text="AMOUNT (RWF)" styleClass="form-section-label"/>
                    <TextField fx:id="amountField" promptText="0"
                               styleClass="input-field" maxWidth="Infinity"/>

                    <!-- Fee display -->
                    <Label fx:id="feeLabel" text=""
                           style="-fx-text-fill:#F5A623; -fx-font-size:13px; -fx-font-weight:bold;"/>

                    <Label text="DESCRIPTION" styleClass="form-section-label"/>
                    <TextField fx:id="descField" promptText="e.g. Payment for services"
                               styleClass="input-field" maxWidth="Infinity"/>

                    <Label text="CONFIRM PIN" styleClass="form-section-label"/>
                    <PasswordField fx:id="pinField" promptText="Enter your PIN"
                                   styleClass="input-field" maxWidth="Infinity"/>

                    <Label fx:id="statusLabel" styleClass="msg-error"
                           wrapText="true" maxWidth="Infinity" minHeight="20"/>

                    <Button text="SEND MONEY" styleClass="btn-teal"
                            maxWidth="Infinity" onAction="#onSend"/>
                </VBox>

                <!-- Recent transfers -->
                <Label text="RECENT TRANSFERS" styleClass="section-header"/>
                <VBox fx:id="recentTransfersBox" spacing="10"/>

                <Region prefHeight="20"/>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom nav -->
    <bottom>
        <HBox styleClass="bottom-nav-bar" alignment="CENTER">
            <Button styleClass="nav-btn" onAction="#onHome" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3">
                    <Label text="🏠" styleClass="nav-btn-icon"/>
                    <Label text="Home" styleClass="nav-btn-label"/>
                </VBox></graphic>
            </Button>
            <Button styleClass="nav-btn" onAction="#onSendMoney" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3">
                    <Label text="✈" styleClass="nav-btn-icon-active"/>
                    <Label text="Send" styleClass="nav-btn-label-active"/>
                </VBox></graphic>
            </Button>
            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <Circle radius="31" fill="#F5A623"
                        style="-fx-effect: dropshadow(gaussian,rgba(245,166,35,0.5),12,0,0,0);"/>
                <VBox alignment="CENTER" spacing="1"
                      onMouseClicked="#onSendMoney" style="-fx-cursor:hand;">
                    <Label text="IRO" style="-fx-text-fill:#0D4F6C; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <Label text="Pay"  style="-fx-text-fill:#0D4F6C; -fx-font-size:10px;"/>
                </VBox>
            </StackPane>
            <Button styleClass="nav-btn" onAction="#onTransactions" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3">
                    <Label text="📋" styleClass="nav-btn-icon"/>
                    <Label text="History" styleClass="nav-btn-label"/>
                </VBox></graphic>
            </Button>
            <Button styleClass="nav-btn" onAction="#onShowAccount" HBox.hgrow="ALWAYS">
                <graphic><VBox alignment="CENTER" spacing="3">
                    <Label text="⚙" styleClass="nav-btn-icon"/>
                    <Label text="Settings" styleClass="nav-btn-label"/>
                </VBox></graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
