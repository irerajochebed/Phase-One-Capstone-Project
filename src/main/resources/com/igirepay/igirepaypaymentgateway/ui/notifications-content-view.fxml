<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.igirepay.igirepaypaymentgateway.ui.controller.NotificationsContentController"
      spacing="20" style="-fx-padding: 24 20 20 20; -fx-background-color:white;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🔔 Notifications" 
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="markAllReadBtn" text="✓ Mark All Read" 
                styleClass="btn-secondary" onAction="#onMarkAllRead"/>
        <Button text="🔄 Refresh" 
                styleClass="btn-secondary" onAction="#onRefresh"/>
    </HBox>

    <!-- Filter Tabs -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="filterAllBtn" text="All" 
                styleClass="filter-btn-active" onAction="#onFilterAll"/>
        <Button fx:id="filterUnreadBtn" text="Unread" 
                styleClass="filter-btn" onAction="#onFilterUnread"/>
        <Button fx:id="filterActionsBtn" text="Action Required" 
                styleClass="filter-btn" onAction="#onFilterActions"/>
    </HBox>

    <!-- Notifications List -->
    <ScrollPane styleClass="scroll-pane" fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="notificationsBox" spacing="12" style="-fx-padding: 10;"/>
    </ScrollPane>

</VBox>
